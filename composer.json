{
    "name": "jandres25/aplicacion-web-php",
    "description": "Sistema de Gestión Empresarial PHP",
    "type": "project",
    "require": {
        "php": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Core\\": "core/",
            "Config\\": "config/"
        },
        "files": [
            "config/app.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
